<%# Partial rendered for both initial page load and Turbo Stream updates.
    Structure mirrors phoenix_app/lib/todo_board_web/live/room_live.html.heex
    so the visual output is identical. -%>
<li id="todo-<%= todo.id %>"
    class="group bg-white rounded-lg border border-gray-200 px-4 py-3
           flex items-center gap-3 transition-opacity
           <%= 'opacity-60' if todo.completed? %>"
    data-controller="todo"
    data-todo-todo-id-value="<%= todo.id %>"
    data-todo-room-id-value="<%= todo.room_id %>">

  <%# Checkbox toggle — Stimulus submits PATCH via fetch -%>
  <button
    type="button"
    data-action="click->todo#toggle"
    class="w-5 h-5 rounded border-2 flex-shrink-0 flex items-center justify-center
           transition-colors
           <%= todo.completed? ? 'bg-blue-600 border-blue-600' : 'border-gray-300 hover:border-blue-400' %>">
    <% if todo.completed? %>
      <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="3">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    <% end %>
  </button>

  <%# Content area — text or inline edit form -%>
  <span class="flex-1 text-sm text-gray-800 select-none
               <%= 'line-through text-gray-400' if todo.completed? %>"
        data-todo-target="label"
        data-action="dblclick->todo#startEdit">
    <%= todo.content %>
  </span>

  <%# Inline edit form — hidden until todo#startEdit -%>
  <%= form_with url: room_todo_path(todo.room_id, todo),
                method: :patch,
                data: { todo_target: "editForm",
                        action: "submit->todo#saveEdit" },
                class: "flex-1 hidden flex gap-2" do |f| %>
    <%= f.text_field :content,
          value: todo.content,
          data: { todo_target: "editInput",
                  action: "keydown->todo#cancelEditOnEscape" },
          class: "flex-1 border border-blue-400 rounded px-2 py-0.5 text-sm
                  focus:outline-none focus:ring-1 focus:ring-blue-500" %>
    <%= f.submit "Save",
          class: "text-xs text-blue-600 font-medium px-2 hover:text-blue-800 cursor-pointer" %>
    <button type="button" data-action="click->todo#cancelEdit"
            class="text-xs text-gray-400 px-2 hover:text-gray-600">✕</button>
  <% end %>

  <%# Edit / Delete buttons -%>
  <div class="opacity-0 group-hover:opacity-100 flex gap-1 transition-opacity"
       data-todo-target="actions">
    <button type="button"
            data-action="click->todo#startEdit"
            title="Edit"
            class="text-gray-300 hover:text-gray-600 p-1 rounded transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652
                 L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685
                 a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
      </svg>
    </button>
    <button type="button"
            data-action="click->todo#destroy"
            title="Delete"
            class="text-gray-300 hover:text-red-500 p-1 rounded transition-colors">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24"
           stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21
                 c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673
                 a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0
                 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0
                 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0
                 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91
                 -2.164-2.09-2.201a51.964 51.964 0 00-3.32
                 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667
                 48.667 0 00-7.5 0" />
      </svg>
    </button>
  </div>
</li>
